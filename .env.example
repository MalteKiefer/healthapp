# HealthVault — Environment Configuration
# Copy to .env and fill in all required values before first run.

# ── Instance ─────────────────────────────────────────────────────────
# The hostname your HealthVault instance is reachable at.
# Examples: healthvault.home, healthvault.example.com, localhost
INSTANCE_HOSTNAME=healthvault.local

# Registration mode: open, invite_only, closed
REGISTRATION_MODE=invite_only

# ── PostgreSQL ───────────────────────────────────────────────────────
# Superuser — used only for initial DB setup, not by the application
DB_SUPERUSER=postgres
DB_SUPERUSER_PASSWORD=CHANGE_ME_superuser_password

# Application user — used by the API via PgBouncer
DB_USER=healthvault
DB_PASSWORD=CHANGE_ME_app_password
DB_NAME=healthvault

# Read-only user — used for export/reporting queries
DB_READONLY_PASSWORD=CHANGE_ME_readonly_password

# ── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Backup ───────────────────────────────────────────────────────────
# AES-256 encryption key for backup files (generate: openssl rand -base64 32)
BACKUP_ENCRYPTION_KEY=CHANGE_ME_backup_encryption_key

# How often to run backups in seconds (default: 86400 = 24 hours)
BACKUP_INTERVAL=86400

# How many days to keep old backups (default: 30)
BACKUP_RETENTION_DAYS=30

# ── Storage Quotas ───────────────────────────────────────────────────
# Default per-user storage quota in MB (default: 5120 = 5 GB)
DEFAULT_QUOTA_MB=5120

# Maximum single file upload size in MB (default: 50)
MAX_FILE_SIZE_MB=50

# ── PgBouncer ────────────────────────────────────────────────────────
# PostgreSQL max_connections must be >= pool_size + reserve_pool_size + 5
# With default Medium preset: max_connections >= 20 + 5 + 5 = 30
# See deploy/pgbouncer/pgbouncer.ini for sizing presets
