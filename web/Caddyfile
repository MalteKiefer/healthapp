:80 {
    root * /srv

    # Serve static files first — only fall back to index.html for non-existing paths
    @existing file {path}
    handle @existing {
        file_server
    }

    # SPA routing — only for paths that don't match actual files
    handle {
        rewrite * /index.html
        file_server
    }

    # Cache busting for hashed assets
    @assets path *.js *.css *.woff2 *.png *.svg *.ico *.wasm
    header @assets Cache-Control "public, max-age=31536000, immutable"
}
